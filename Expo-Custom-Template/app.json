{
  "expo": {
    "name": "Prompt Paradise",
    "slug": "prompt-paradise",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/prompt_paradise_logo.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "updates": {
      "url": "https://u.expo.dev/YOUR-PROJECT-ID"
    },
    "runtimeVersion": "1.0.0",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/prompt_paradise_logo.png",
      "resizeMode": "cover",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },

    "android": {

      "package": "com.mycompany.myapp",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "INTERNET"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#232323",
          "image": "./assets/images/prompt_paradise_logo.png",
          "dark": {
            "image": "./assets/images/prompt_paradise_logo.png",
            "backgroundColor": "#000000"
          },
          "resizeMode": "cover"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
